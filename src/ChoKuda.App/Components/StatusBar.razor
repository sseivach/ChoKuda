<footer class="status-bar">
    <span>Visible: @VisiblePointCount / Total: @TotalPointCount</span>
    <span>@Message</span>
    <div class="status-action">
        @if (CanChangeMapStyle)
        {
            <MapStyleSelect Label="Map"
                            CssClass="map-style-select status-map-style"
                            StyleOptions="@MapStyleOptions"
                            SelectedStyleId="@SelectedMapStyleId"
                            OnStyleChanged="OnMapStyleChanged" />
            <label class="map-option-toggle status-map-toggle">
                <input type="checkbox"
                       checked="@UseLargeMapLabels"
                       @onchange="UpdateLargeMapLabels" />
                <span>Large labels</span>
            </label>
        }
        <span class="@OperationStatusClass">@OperationStatus: @OperationMessage</span>
        @if (CanRetryOperation)
        {
            <button @onclick="OnRetryOperation">Retry</button>
        }
        <span class="muted">@SelectedCoordinateStatus</span>
        <button type="button" @onclick="OnOpenAdmin">Admin</button>
        <button disabled="@AddPointDisabled" @onclick="OnAddPoint">Add point</button>
    </div>
</footer>

@code {
    [Parameter]
    public int VisiblePointCount { get; set; }

    [Parameter]
    public int TotalPointCount { get; set; }

    [Parameter]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public string SelectedCoordinateStatus { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<StadiaMapStyle> MapStyleOptions { get; set; } = Array.Empty<StadiaMapStyle>();

    [Parameter]
    public string SelectedMapStyleId { get; set; } = StadiaMapStyles.DefaultStyleId;

    [Parameter]
    public bool UseLargeMapLabels { get; set; }

    [Parameter]
    public bool CanChangeMapStyle { get; set; }

    [Parameter]
    public EventCallback<string> OnMapStyleChanged { get; set; }

    [Parameter]
    public EventCallback<bool> OnLargeMapLabelsChanged { get; set; }

    [Parameter]
    public UiOperationStatus OperationStatus { get; set; } = UiOperationStatus.Idle;

    [Parameter]
    public string OperationMessage { get; set; } = string.Empty;

    [Parameter]
    public bool CanRetryOperation { get; set; }

    [Parameter]
    public bool AddPointDisabled { get; set; }

    [Parameter]
    public EventCallback OnAddPoint { get; set; }

    [Parameter]
    public EventCallback OnRetryOperation { get; set; }

    [Parameter]
    public EventCallback OnOpenAdmin { get; set; }

    private string OperationStatusClass =>
        $"operation-status {OperationStatus.ToString().ToLowerInvariant()}";

    private async Task UpdateLargeMapLabels(ChangeEventArgs eventArgs)
    {
        await OnLargeMapLabelsChanged.InvokeAsync(eventArgs.Value is true);
    }
}
