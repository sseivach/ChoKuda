    private async Task SavePoint()
    {
        if (_pointForm is null)
        {
            return;
        }

        var paths = GetCurrentLibraryPaths();
        if (paths is null)
        {
            return;
        }

        ClearPointErrors();
        var result = _isNewPoint
            ? PointService.CreatePoint(paths, _pointForm)
            : PointService.UpdatePoint(paths, _pointForm);

        if (!result.IsSuccess || result.Point is null)
        {
            ApplySaveErrors(result.Errors);
            return;
        }

        var savedPoint = result.Point;

        if (_pendingAttachments.Count > 0)
        {
            var importResult = AttachmentImportService.ImportPendingAttachments(
                paths,
                savedPoint,
                _pendingAttachments);

            _attachmentErrors = importResult.Errors
                .Select(error => $"{Path.GetFileName(error.SourcePath)}: {error.Message}")
                .ToArray();
            _pendingAttachments = [];

            var attachmentSaveResult = PointService.UpdatePoint(paths, importResult.Point);

            if (!attachmentSaveResult.IsSuccess || attachmentSaveResult.Point is null)
            {
                ApplySaveErrors(attachmentSaveResult.Errors);
                _attachmentErrors = _attachmentErrors
                    .Concat(["Imported files were copied, but point JSON could not be updated. Try saving again."])
                    .ToArray();
                _pointForm = ClonePoint(importResult.Point);
                _savedPointSnapshot = ClonePoint(savedPoint);
                LoadLibraryData();
                await InvokeAsync(StateHasChanged);
                return;
            }
            else
            {
                savedPoint = attachmentSaveResult.Point;
            }
        }

        _pointForm = ClonePoint(savedPoint);
        _savedPointSnapshot = ClonePoint(savedPoint);
        _isNewPoint = false;
        _selectedCoordinate = null;
        LoadLibraryData();
        await InvokeAsync(StateHasChanged);
    }

