@namespace ChoKuda.App.Components
@implements IDisposable
@inject AppShellState ShellState
@inject AppEnvironmentPaths EnvironmentPaths
@inject LibraryCoordinator LibraryCoordinator
@inject PointService PointService
@inject CollectionService CollectionService
@inject AttachmentFileClassifier AttachmentFileClassifier
@inject AttachmentImportService AttachmentImportService
@inject AttachmentDeleteService AttachmentDeleteService
@inject AttachmentDropService AttachmentDropService
@inject IAttachmentFilePicker AttachmentFilePicker
@inject IAttachmentOpener AttachmentOpener
@inject BootstrapIconCatalog BootstrapIconCatalog
@inject ILibraryFolderPicker LibraryFolderPicker
@inject IApplicationShutdown ApplicationShutdown
@inject IJSRuntime JsRuntime

<main class="@ShellClass">
    <LeftPanel ShellState="ShellState"
               Search="_search"
               Filters="_filters"
               CollectionEditor="_collectionEditor"
               SearchResults="_data.SearchResults"
               Collections="_data.Collections"
               Tags="_data.TagIndex"
               OnSearch="RunSearch"
               OnResetSearch="ResetSearch"
               OnSearchResultSelected="OpenSearchResult"
               OnNewCollection="NewCollection"
               OnEditCollection="EditCollection"
               OnSaveCollection="SaveCollection"
               OnCancelCollectionEdit="CancelCollectionEdit"
               OnDeleteCollection="DeleteCollection"
               OnFilterChanged="ApplyFiltersAndMapProjection" />

    <MapWorkspace @ref="_mapWorkspace"
                  IsLibraryReady="@IsLibraryReady"
                  HasStadiaApiKey="@HasStadiaApiKey"
                  StadiaApiKey="@StadiaApiKey"
                  StadiaApiKeyInput="@_stadiaApiKeyInput"
                  Points="@_data.MapPoints"
                  TemporaryMarker="@_pointEditor.SelectedCoordinate"
                  LibrarySetupTitle="@_library.SetupTitle"
                  LibrarySetupMessage="@_library.SetupMessage"
                  LibrarySetupErrors="@_library.SetupErrors"
                  DefaultLibraryPath="@DefaultLibraryPath"
                  OnStadiaApiKeyInputChanged="UpdateStadiaApiKeyInput"
                  OnSaveStadiaApiKey="SaveStadiaApiKey"
                  OnCreateDefaultLibrary="CreateDefaultLibrary"
                  OnChooseLibrary="ChooseLibrary"
                  OnExit="ApplicationShutdown.Shutdown"
                  OnMapClick="HandleMapClick"
                  OnPointClick="HandlePointClick"
                  OnEscape="ClearSelectedCoordinate" />

    <PointPanel IsOpen="@ShellState.IsRightPanelOpen"
                Editor="_pointEditor"
                Collections="_data.Collections"
                Photos="PhotoItems"
                Files="FileItems"
                AttachmentErrors="_attachments.Errors"
                OnClose="ClosePointPanel"
                OnSave="SavePoint"
                OnDelete="DeletePoint"
                OnAddFiles="AddPendingAttachments"
                OnRemoveAttachment="RemoveAttachment"
                OnOpenAttachment="OpenAttachment"
                OnOpenPhoto="OpenPhotoViewer" />

    @if (_library.LoadErrors.Count > 0)
    {
        <div class="global-error-area">
            <UiErrorPanel Title="Some library JSON files could not be loaded"
                          Description="ChoKuda skipped the broken files and loaded everything else it could read."
                          Messages="_library.LoadErrors"
                          Action="Repair or remove the listed JSON files, then reopen ChoKuda." />
        </div>
    }

    <PhotoViewer PhotoPath="@_attachments.PhotoViewerPath"
                 Zoom="@_attachments.PhotoViewerZoom"
                 OnClose="ClosePhotoViewer"
                 OnZoomIn="ZoomPhotoViewerIn"
                 OnZoomOut="ZoomPhotoViewerOut"
                 OnResetZoom="ResetPhotoViewerZoom" />

    <StatusBar VisiblePointCount="@_data.FilteredPoints.Count"
               TotalPointCount="@_data.AllPoints.Count"
               Message="@StatusMessage"
               SelectedCoordinateStatus="@_pointEditor.SelectedCoordinateStatus"
               OperationStatus="@_operation.Status"
               OperationMessage="@_operation.Message"
               CanRetryOperation="@_operation.CanRetry"
               OnRetryOperation="RetryOperation"
               AddPointDisabled="@IsAddPointDisabled"
               OnAddPoint="OpenNewPointPanel" />
</main>

@code {
    private AppSettings _appSettings = new();
    private MapWorkspace? _mapWorkspace;
    private readonly SearchViewModel _search = new();
    private readonly FilterViewModel _filters = new();
    private readonly LibraryDataViewModel _data = new();
    private readonly PointEditorViewModel _pointEditor = new();
    private readonly AttachmentDraftState _attachments = new();
    private readonly CollectionEditorViewModel _collectionEditor = new();
    private readonly LibraryViewModel _library = new();
    private readonly UiOperationViewModel _operation = new();
    private string _stadiaApiKeyInput = string.Empty;

    private CollectionDocument? _collectionForm =>
        _collectionEditor.Form;

    private bool _isNewCollection =>
        _collectionEditor.IsNew;

    private PointDocument? _pointForm =>
        _pointEditor.Form;

    private bool _isNewPoint =>
        _pointEditor.IsNew;

    private bool IsLibraryReady =>
        _library.IsReady;

    private string DefaultLibraryPath => EnvironmentPaths.DefaultLibraryPath;

    private bool HasStadiaApiKey =>
        !string.IsNullOrWhiteSpace(_appSettings.StadiaApiKey);

    private string StadiaApiKey =>
        _appSettings.StadiaApiKey ?? string.Empty;

    private bool IsAddPointDisabled =>
        !_pointEditor.CanOpenNewPoint(IsLibraryReady, ShellState.IsRightPanelOpen);

    private string StatusMessage =>
        $"Search: {(_search.IsActive ? "active" : "none")} | " +
        $"Collections: {_filters.SelectedCollectionIds.Count} {_filters.CollectionMode.ToString().ToUpperInvariant()} | " +
        $"Tags: {_filters.SelectedTags.Count} {_filters.TagMode.ToString().ToUpperInvariant()} | " +
        $"JSON errors: {_library.LoadErrors.Count}";

    private string ShellClass =>
        ShellState.IsLeftPanelCollapsed
            ? "app-shell left-collapsed"
            : "app-shell";

    private bool HasUnsavedCollectionChanges =>
        _collectionEditor.HasUnsavedChanges;

    private IEnumerable<AttachmentDisplayItem> PhotoItems =>
        _attachments.GetDisplayItems(
            AttachmentKind.Photo,
            _pointForm,
            GetCurrentLibraryPaths()?.PhotosPath);

    private IEnumerable<AttachmentDisplayItem> FileItems =>
        _attachments.GetDisplayItems(
            AttachmentKind.File,
            _pointForm,
            GetCurrentLibraryPaths()?.FilesPath);

    protected override async Task OnInitializedAsync()
    {
        ShellState.Changed += HandleStateChanged;
        AttachmentDropService.FilesDropped += HandleAttachmentFilesDropped;
        _collectionEditor.SetIconIds(BootstrapIconCatalog.LoadIconIds());
        await LoadLibraryState();
    }

    public void Dispose()
    {
        ShellState.Changed -= HandleStateChanged;
        AttachmentDropService.FilesDropped -= HandleAttachmentFilesDropped;
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task LoadLibraryState()
    {
        _appSettings = LibraryCoordinator.LoadSettings();
        _stadiaApiKeyInput = _appSettings.StadiaApiKey ?? string.Empty;

        if (string.IsNullOrWhiteSpace(_appSettings.LibraryPath))
        {
            _library.SetNoLibrarySelected();
            _operation.SetIdle("Choose a library to start.");
            return;
        }

        if (!LibraryCoordinator.LibraryFolderExists(_appSettings.LibraryPath))
        {
            _library.SetMissingLibrary(_appSettings.LibraryPath);
            _operation.SetError("Saved library folder is missing.", UiRetryAction.PrepareLibrary);
            return;
        }

        await UseLibrary(_appSettings.LibraryPath, showLoading: false);
    }

    private async Task CreateDefaultLibrary()
    {
        await UseLibrary(DefaultLibraryPath);
    }

    private async Task ChooseLibrary()
    {
        var selectedPath = LibraryFolderPicker.PickFolder(_library.Path ?? DefaultLibraryPath);

        if (!string.IsNullOrWhiteSpace(selectedPath))
        {
            await UseLibrary(selectedPath);
        }
    }

    private async Task UseLibrary(string libraryPath, bool showLoading = true)
    {
        if (showLoading)
        {
            _operation.SetLoading("Opening library...");
            await InvokeAsync(StateHasChanged);
        }

        var result = LibraryCoordinator.OpenLibrary(libraryPath, _appSettings);
        if (!result.IsSuccess)
        {
            _library.SetOpenFailed(libraryPath, result.ErrorMessage ?? "Unknown error.");
            _operation.SetError("Library folder could not be opened.", UiRetryAction.PrepareLibrary);
            return;
        }

        _library.SetReady(libraryPath);
        ReloadLibraryDataAndSetSuccess("Library is ready.");
    }

    private bool LoadLibraryData()
    {
        var paths = GetCurrentLibraryPaths();
        if (paths is null)
        {
            _library.ClearLoadErrors();
            _data.Clear(_search, _filters);
            return true;
        }

        var result = LibraryCoordinator.LoadData(paths);
        if (!result.IsSuccess)
        {
            _library.SetLoadFailed(_library.Path ?? string.Empty, result.ErrorMessage ?? "Unknown error.");
            _operation.SetError("Library data could not be loaded.", UiRetryAction.ReloadLibrary);
            return false;
        }

        _library.SetLoadErrors(result.PointErrors, result.CollectionErrors);
        _data.SetLoaded(result.Points, result.Collections, _search, _filters);

        if (_library.HasLoadErrors)
        {
            _operation.SetError("Library loaded with JSON errors.", UiRetryAction.ReloadLibrary);
        }

        return true;
    }

    private bool ReloadLibraryDataAndSetSuccess(string successMessage)
    {
        var loaded = LoadLibraryData();
        if (loaded && !_library.HasLoadErrors)
        {
            _operation.SetSuccess(successMessage);
        }

        return loaded;
    }

    private void ApplyFiltersAndMapProjection()
    {
        _data.RebuildProjection(_search, _filters);
    }

    private void SaveStadiaApiKey()
    {
        _operation.SetLoading("Saving map settings...");

        _appSettings.StadiaApiKey = string.IsNullOrWhiteSpace(_stadiaApiKeyInput)
            ? null
            : _stadiaApiKeyInput.Trim();

        var result = LibraryCoordinator.SaveSettings(_appSettings);
        if (!result.IsSuccess)
        {
            _operation.SetError($"Map settings could not be saved. Reason: {result.ErrorMessage ?? "Unknown error."}");
            return;
        }

        _operation.SetSuccess("Map settings saved.");
    }

    private void UpdateStadiaApiKeyInput(string value)
    {
        _stadiaApiKeyInput = value;
    }

    private void HandleMapClick(MapCoordinate coordinate)
    {
        _pointEditor.SelectCoordinate(coordinate, ShellState.IsRightPanelOpen);
    }

    private async Task HandlePointClick(Guid pointId)
    {
        await OpenSavedPoint(pointId);
    }

    private async Task OpenSearchResult(Guid pointId)
    {
        var point = _data.FindPoint(pointId);

        if (point is null)
        {
            LoadLibraryData();
            return;
        }

        if (await OpenSavedPoint(pointId) && _mapWorkspace is not null)
        {
            await _mapWorkspace.CenterOnAsync(point.Latitude, point.Longitude);
        }
    }

    private async Task<bool> OpenSavedPoint(Guid pointId)
    {
        if (!await ConfirmDiscardChangesIfNeeded())
        {
            return false;
        }

        var paths = GetCurrentLibraryPaths();
        if (paths is null)
        {
            return false;
        }

        if (!_pointEditor.OpenSavedPoint(paths, pointId, PointService, _attachments))
        {
            LoadLibraryData();
            return false;
        }

        ShellState.OpenRightPanelPreview();
        return true;
    }

    private void ClearSelectedCoordinate()
    {
        _pointEditor.ClearSelectedCoordinate(ShellState.IsRightPanelOpen);
    }

    private void OpenNewPointPanel()
    {
        if (!_pointEditor.OpenNewFromSelectedCoordinate(PointService, _attachments))
        {
            return;
        }

        ShellState.OpenRightPanelPreview();
    }

    private async Task SavePoint()
    {
        if (_pointForm is null)
        {
            return;
        }

        var paths = GetCurrentLibraryPaths();
        if (paths is null)
        {
            return;
        }

        await StartOperation("Saving point...");
        ClearAttachmentErrors();
        var saveResult = _pointEditor.SaveWithAttachments(paths, PointService, AttachmentImportService, _attachments);

        if (!saveResult.IsSuccess)
        {
            if (saveResult.ShouldReloadLibrary)
            {
                LoadLibraryData();
                await InvokeAsync(StateHasChanged);
            }

            _operation.SetError("Point could not be saved.");
            return;
        }

        ReloadLibraryDataAndSetSuccess("Point saved.");

        await InvokeAsync(StateHasChanged);
    }

    private async Task DeletePoint()
    {
        if (_pointForm is null || _isNewPoint)
        {
            return;
        }

        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Delete this point?");

        if (!confirmed)
        {
            return;
        }

        var paths = GetCurrentLibraryPaths();
        if (paths is null)
        {
            return;
        }

        await StartOperation("Deleting point...");
        if (!_pointEditor.Delete(paths, PointService, _attachments))
        {
            _operation.SetError("Point could not be deleted.");
            return;
        }

        ShellState.CloseRightPanel();
        ReloadLibraryDataAndSetSuccess("Point deleted.");
    }

    private async Task ClosePointPanel()
    {
        if (!await ConfirmDiscardChangesIfNeeded())
        {
            return;
        }

        _pointEditor.Clear();
        _attachments.ClearAll();
        ClearPointErrors();
        ShellState.CloseRightPanel();
    }

    private async Task<bool> ConfirmDiscardChangesIfNeeded()
    {
        if (!_pointEditor.RequiresDiscardConfirmation)
        {
            return true;
        }

        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Discard changes?");
        return _pointEditor.CanDiscardChanges(confirmed);
    }

    private async Task NewCollection()
    {
        if (!await ConfirmDiscardCollectionChangesIfNeeded())
        {
            return;
        }

        _collectionEditor.OpenNew(CollectionService);
    }

    private async Task EditCollection(Guid collectionId)
    {
        if (!await ConfirmDiscardCollectionChangesIfNeeded())
        {
            return;
        }

        if (!_collectionEditor.OpenExisting(collectionId, _data.Collections))
        {
            LoadLibraryData();
            return;
        }
    }

    private async Task SaveCollection()
    {
        var paths = GetCurrentLibraryPaths();
        if (paths is null)
        {
            return;
        }

        await StartOperation("Saving collection...");
        var savedCollection = _collectionEditor.Save(paths, CollectionService, _data.Collections);

        if (savedCollection is null)
        {
            _operation.SetError("Collection could not be saved.");
            return;
        }

        ReloadLibraryDataAndSetSuccess("Collection saved.");

        await InvokeAsync(StateHasChanged);
    }

    private async Task DeleteCollection()
    {
        if (_collectionForm is null || _isNewCollection)
        {
            return;
        }

        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Delete this collection?");

        if (!confirmed)
        {
            return;
        }

        var paths = GetCurrentLibraryPaths();
        if (paths is null)
        {
            return;
        }

        await StartOperation("Deleting collection...");
        if (!_collectionEditor.Delete(paths, CollectionService))
        {
            _operation.SetError("Collection could not be deleted.");
            return;
        }

        ReloadLibraryDataAndSetSuccess("Collection deleted.");
    }

    private async Task CancelCollectionEdit()
    {
        if (!await ConfirmDiscardCollectionChangesIfNeeded())
        {
            return;
        }

        _collectionEditor.Clear();
    }

    private async Task<bool> ConfirmDiscardCollectionChangesIfNeeded()
    {
        if (!_collectionEditor.RequiresDiscardConfirmation)
        {
            return true;
        }

        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Discard changes?");
        return _collectionEditor.CanDiscardChanges(confirmed);
    }

    private void RunSearch()
    {
        if (!_search.Run())
        {
            return;
        }

        ApplyFiltersAndMapProjection();
    }

    private void ResetSearch()
    {
        _search.Reset();
        ApplyFiltersAndMapProjection();
    }

    private async Task RetryOperation()
    {
        switch (_operation.RetryAction)
        {
            case UiRetryAction.PrepareLibrary:
                await UseLibrary(_library.Path ?? _appSettings.LibraryPath ?? DefaultLibraryPath);
                break;

            case UiRetryAction.ReloadLibrary:
                await StartOperation("Reloading library...");
                ReloadLibraryDataAndSetSuccess("Library reloaded.");

                await InvokeAsync(StateHasChanged);
                break;
        }
    }

    private async Task StartOperation(string message)
    {
        _operation.SetLoading(message);
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
    }

    private FileLibraryPaths? GetCurrentLibraryPaths()
    {
        return _library.GetCurrentPaths();
    }

    private void AddPendingAttachments()
    {
        StageAttachmentFiles(
            AttachmentFilePicker.PickFiles(),
            "Attachment files staged.",
            noFilesMessage: null);
    }

    private void HandleAttachmentFilesDropped(object? sender, AttachmentFilesDroppedEventArgs eventArgs)
    {
        _ = InvokeAsync(() => StageAttachmentFiles(
            eventArgs.FilePaths,
            "Attachment files dropped.",
            "Drop files onto an open point panel."));
    }

    private void StageAttachmentFiles(
        IEnumerable<string> filePaths,
        string successMessage,
        string? noFilesMessage)
    {
        if (_pointForm is null)
        {
            if (!string.IsNullOrWhiteSpace(noFilesMessage))
            {
                _operation.SetError(noFilesMessage);
            }

            return;
        }

        var stageResult = _attachments.StageFiles(
            filePaths,
            File.Exists,
            filePath => AttachmentFileClassifier.Classify(filePath));

        if (!stageResult.HasExistingFiles)
        {
            if (!string.IsNullOrWhiteSpace(noFilesMessage))
            {
                _operation.SetError(noFilesMessage);
            }

            return;
        }

        if (stageResult.HasAddedFiles)
        {
            _operation.SetSuccess($"{successMessage} Added: {stageResult.AddedCount}.");
        }
        else
        {
            _operation.SetIdle("Attachment files were already staged.");
        }
    }

    private async Task RemoveAttachment(AttachmentDisplayItem item)
    {
        if (_pointForm is null)
        {
            return;
        }

        ClearAttachmentErrors();

        if (item.IsPending)
        {
            _attachments.RemovePending(item);
            _operation.SetSuccess("Pending attachment removed.");
            return;
        }

        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Delete this attachment?");

        if (!confirmed)
        {
            return;
        }

        var paths = GetCurrentLibraryPaths();
        if (paths is null)
        {
            return;
        }

        if (!_pointEditor.DeleteSavedAttachment(item, _attachments, paths, AttachmentDeleteService))
        {
            _operation.SetError("Attachment could not be deleted.");
            return;
        }

        ReloadLibraryDataAndSetSuccess("Attachment deleted.");
    }

    private void OpenAttachment(AttachmentDisplayItem item)
    {
        _attachments.OpenFile(item, AttachmentOpener.Open);
        if (_attachments.Errors.Count > 0)
        {
            _operation.SetError("Attachment could not be opened.");
        }
        else
        {
            _operation.SetSuccess("Attachment opened.");
        }
    }

    private void OpenPhotoViewer(string photoPath)
    {
        _attachments.OpenPhotoViewer(photoPath);
    }

    private void ClosePhotoViewer()
    {
        _attachments.ClosePhotoViewer();
    }

    private void ZoomPhotoViewerIn()
    {
        _attachments.ZoomPhotoViewerIn();
    }

    private void ZoomPhotoViewerOut()
    {
        _attachments.ZoomPhotoViewerOut();
    }

    private void ResetPhotoViewerZoom()
    {
        _attachments.ResetPhotoViewerZoom();
    }

    private void ClearPointErrors()
    {
        _pointEditor.ClearErrors();
        _attachments.ClearErrors();
    }

    private void ClearAttachmentErrors()
    {
        _attachments.ClearErrors();
    }

}
