    private void TogglePointCollection(Guid collectionId, bool isSelected)
    {
        if (_pointForm is null)
        {
            return;
        }

        if (isSelected)
        {
            if (!_pointForm.CollectionIds.Contains(collectionId))
            {
                _pointForm.CollectionIds.Add(collectionId);
            }

            _pointForm.PrimaryCollectionId = PointCollectionRules.AddCollection(
                _pointForm.CollectionIds,
                _pointForm.PrimaryCollectionId,
                collectionId);
            return;
        }

        _pointForm.CollectionIds.Remove(collectionId);
        _pointForm.PrimaryCollectionId = PointCollectionRules.RemoveCollection(
            _pointForm.CollectionIds,
            collectionId,
            _pointForm.PrimaryCollectionId,
            _collections.Select(collection => new CollectionSummary(collection.Id, collection.Name)).ToArray());
    }

    private void HandlePrimaryCollectionChanged(ChangeEventArgs eventArgs)
    {
        if (_pointForm is null)
        {
            return;
        }

        var value = eventArgs.Value?.ToString();
        _pointForm.PrimaryCollectionId =
            Guid.TryParse(value, out var collectionId) && _pointForm.CollectionIds.Contains(collectionId)
                ? collectionId
                : null;
    }

