    private void StartCollectionFilterDrag(Guid collectionId)
    {
        _draggedCollectionFilterId = collectionId;
    }

    private void DropCollectionFilter(Guid targetCollectionId)
    {
        if (!_draggedCollectionFilterId.HasValue ||
            _draggedCollectionFilterId.Value == targetCollectionId)
        {
            _draggedCollectionFilterId = null;
            return;
        }

        _selectedCollectionFilterIds.Remove(_draggedCollectionFilterId.Value);
        var targetIndex = _selectedCollectionFilterIds.IndexOf(targetCollectionId);
        _selectedCollectionFilterIds.Insert(targetIndex, _draggedCollectionFilterId.Value);
        _draggedCollectionFilterId = null;
        ApplyFiltersAndMapProjection();
    }

    private FileLibraryPaths? GetCurrentLibraryPaths()
    {
        if (!IsLibraryReady || string.IsNullOrWhiteSpace(LibraryPath))
        {
            return null;
        }

        return new FileLibraryPaths(LibraryPath);
    }

    private void AddPendingAttachments()
    {
        if (_pointForm is null)
        {
            return;
        }

        var selectedFiles = AttachmentFilePicker.PickFiles();

        foreach (var filePath in selectedFiles)
        {
            if (_pendingAttachments.Any(attachment => string.Equals(attachment.SourcePath, filePath, StringComparison.OrdinalIgnoreCase)))
            {
                continue;
            }

            _pendingAttachments.Add(new PendingAttachment(
                filePath,
                AttachmentFileClassifier.Classify(filePath)));
        }
    }

    private async Task RemoveAttachment(AttachmentDisplayItem item)
    {
        if (_pointForm is null)
        {
            return;
        }

        ClearAttachmentErrors();

        if (item.IsPending)
        {
            _pendingAttachments.RemoveAll(attachment => attachment.SourcePath == item.Path && attachment.Kind == item.Kind);
            return;
        }

        var confirmed = await JsRuntime.InvokeAsync<bool>("confirm", "Delete this attachment?");

        if (!confirmed)
        {
            return;
        }

        var paths = GetCurrentLibraryPaths();
        if (paths is null)
        {
            return;
        }

        var result = AttachmentDeleteService.DeleteSavedAttachment(
            paths,
            _pointForm,
            item.Kind,
            item.StoredName);

        if (!result.IsSuccess)
        {
            _attachmentErrors = result.Errors;
            return;
        }

        _pointForm = ClonePoint(result.Point);
        _savedPointSnapshot = ClonePoint(result.Point);
        LoadLibraryData();
    }

    private void OpenAttachment(AttachmentDisplayItem item)
    {
        ClearAttachmentErrors();
        var error = AttachmentOpener.Open(item.Path);

        if (!string.IsNullOrWhiteSpace(error))
        {
            _attachmentErrors = [error];
        }
    }

