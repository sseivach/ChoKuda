@namespace ChoKuda.App.Components
@implements IDisposable
@inject AppShellState ShellState
@inject AppEnvironmentPaths EnvironmentPaths
@inject AppSettingsService AppSettingsService
@inject FileLibraryService FileLibraryService
@inject PointService PointService
@inject CollectionService CollectionService
@inject AttachmentFileClassifier AttachmentFileClassifier
@inject AttachmentImportService AttachmentImportService
@inject AttachmentDeleteService AttachmentDeleteService
@inject IAttachmentFilePicker AttachmentFilePicker
@inject IAttachmentOpener AttachmentOpener
@inject ILibraryFolderPicker LibraryFolderPicker
@inject IApplicationShutdown ApplicationShutdown
@inject IJSRuntime JsRuntime

<main class="@ShellClass">
    @if (ShellState.IsLeftPanelCollapsed)
    {
        <aside class="left-rail">
            <button class="icon-button" title="Open navigation" @onclick="ShellState.ToggleLeftPanel">Menu</button>
        </aside>
    }
    else
    {
        <aside class="left-panel">
            <header class="panel-header">
                <div>
                    <h1>ChoKuda</h1>
                    <p>Travel places bank</p>
                </div>
                <button class="icon-button" title="Collapse navigation" @onclick="ShellState.ToggleLeftPanel">Hide</button>
            </header>

            <section class="panel-section">
                <h2>Search</h2>
                <div class="search-row">
                    <input placeholder="Search places" @bind="_searchInput" @bind:event="oninput" />
                    <button disabled="@(!CanRunSearch)" @onclick="RunSearch">Search</button>
                    <button disabled="@(!IsSearchActive)" @onclick="ResetSearch">Reset search</button>
                </div>
            </section>

            <section class="panel-section">
                <h2>Search Results</h2>
                @if (!IsSearchActive)
                {
                    <p class="muted">No active search.</p>
                }
                else if (_filteredPoints.Count == 0)
                {
                    <p class="muted">No points found.</p>
                }
                else
                {
                    <div class="search-results">
                        @foreach (var point in SearchResults)
                        {
                            <button class="search-result-row" @onclick="() => OpenSearchResult(point.Id)">
                                <span>@point.Title</span>
                                @if (!string.IsNullOrWhiteSpace(point.AddressRegion))
                                {
                                    <small>@point.AddressRegion</small>
                                }
                            </button>
                        }
                    </div>
                }
            </section>

            <section class="panel-section collections-section">
                <div class="section-title-row">
                    <h2>Collections</h2>
                    <button class="compact-button" @onclick="NewCollection">+ Collection</button>
                </div>

                @if (_collectionForm is not null)
                {
                    <div class="inline-form">
                        <label>
                            Name
                            <input @bind="_collectionForm.Name" />
                        </label>
                        @if (!string.IsNullOrWhiteSpace(_collectionNameError))
                        {
                            <p class="field-error">@_collectionNameError</p>
                        }

                        <label>
                            Icon
                            <input @bind="_iconSearch" @bind:event="oninput" placeholder="Search icon name" />
                        </label>
                        <div class="icon-grid">
                            @foreach (var iconId in FilteredIconIds)
                            {
                                <button class="@IconChoiceClass(iconId)"
                                        title="@iconId"
                                        @onclick="() => SelectCollectionIcon(iconId)">
                                    <i class="bi bi-@iconId"></i>
                                </button>
                            }
                        </div>

                        <label>
                            Color
                            <span class="color-row">
                                <input type="color" @bind="_collectionForm.Color" />
                                <code>@_collectionForm.Color</code>
                            </span>
                        </label>
                        @if (!string.IsNullOrWhiteSpace(_collectionColorError))
                        {
                            <p class="field-error">@_collectionColorError</p>
                        }

                        <label>
                            Description
                            <textarea class="compact-textarea" @bind="_collectionForm.DescriptionText"></textarea>
                        </label>

                        @if (!string.IsNullOrWhiteSpace(_collectionGeneralError))
                        {
                            <p class="field-error">@_collectionGeneralError</p>
                        }

                        @if (_collectionDeleteErrors.Count > 0)
                        {
                            <div class="error-box">
                                @foreach (var error in _collectionDeleteErrors)
                                {
                                    <p>@error</p>
                                }
                            </div>
                        }

                        <div class="panel-actions inline-actions">
                            <button @onclick="SaveCollection">Save</button>
                            <button @onclick="CancelCollectionEdit">Cancel</button>
                            @if (!_isNewCollection)
                            {
                                <button class="danger-button" @onclick="DeleteCollection">Delete</button>
                            }
                        </div>
                    </div>
                }

                <div class="collection-list">
                    @foreach (var collection in _collections.OrderBy(collection => collection.Name, StringComparer.OrdinalIgnoreCase))
                    {
                        <button class="collection-row" @onclick="() => EditCollection(collection.Id)">
                            <span class="collection-style" style="background:@collection.Color">
                                <i class="bi bi-@IconOrDefault(collection.IconId)"></i>
                            </span>
                            <span>@collection.Name</span>
                        </button>
                    }
                </div>

                <div class="filter-block">
                    <div class="filter-header">
                        <strong>Filter</strong>
                        <button class="compact-button" @onclick="ResetCollectionFilter">Reset collections</button>
                    </div>
                    <div class="segmented-control">
                        <button class="@ModeButtonClass(_collectionFilterMode, FilterMode.Any)"
                                @onclick="() => SetCollectionFilterMode(FilterMode.Any)">
                            OR
                        </button>
                        <button class="@ModeButtonClass(_collectionFilterMode, FilterMode.All)"
                                @onclick="() => SetCollectionFilterMode(FilterMode.All)">
                            AND
                        </button>
                    </div>

                    @foreach (var collection in _collections.OrderBy(collection => collection.Name, StringComparer.OrdinalIgnoreCase))
                    {
                        <label class="check-row">
                            <input type="checkbox"
                                   checked="@_selectedCollectionFilterIds.Contains(collection.Id)"
                                   @onchange="eventArgs => ToggleCollectionFilter(collection.Id, eventArgs.Value is true)" />
                            <span>@collection.Name</span>
                        </label>
                    }

                    @if (_selectedCollectionFilterIds.Count > 0)
                    {
                        <div class="drag-list">
                            @foreach (var collectionId in _selectedCollectionFilterIds)
                            {
                                var collection = FindCollection(collectionId);
                                if (collection is not null)
                                {
                                    <div class="drag-row"
                                         draggable="true"
                                         @ondragstart="() => StartCollectionFilterDrag(collectionId)"
                                         @ondragover:preventDefault="true"
                                         @ondrop="() => DropCollectionFilter(collectionId)">
                                        <i class="bi bi-grip-vertical"></i>
                                        <span class="collection-style small" style="background:@collection.Color">
                                            <i class="bi bi-@IconOrDefault(collection.IconId)"></i>
                                        </span>
                                        <span>@collection.Name</span>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            </section>

            <section class="panel-section tags-section">
                <div class="filter-header">
                    <h2>Tags</h2>
                    <button class="compact-button" @onclick="ResetTagFilter">Reset tags</button>
                </div>
                <div class="segmented-control">
                    <button class="@ModeButtonClass(_tagFilterMode, FilterMode.Any)"
                            @onclick="() => SetTagFilterMode(FilterMode.Any)">
                        OR
                    </button>
                    <button class="@ModeButtonClass(_tagFilterMode, FilterMode.All)"
                            @onclick="() => SetTagFilterMode(FilterMode.All)">
                        AND
                    </button>
                </div>

                @if (_tagIndex.Count == 0)
                {
                    <p class="muted">No tags yet.</p>
                }
                else
                {
                    @foreach (var tag in _tagIndex)
                    {
                        <label class="check-row">
                            <input type="checkbox"
                                   checked="@_selectedTagFilters.Contains(tag)"
                                   @onchange="eventArgs => ToggleTagFilter(tag, eventArgs.Value is true)" />
                            <span>@tag</span>
                        </label>
                    }
                }
            </section>
        </aside>
    }

    <section class="map-stage">
        @if (IsLibraryReady)
        {
            @if (HasStadiaApiKey)
            {
                <MapView @ref="_mapView"
                         ApiKey="@StadiaApiKey"
                         Points="@_mapPoints"
                         TemporaryMarker="@_selectedCoordinate"
                         OnMapClick="HandleMapClick"
                         OnPointClick="HandlePointClick"
                         OnEscape="ClearSelectedCoordinate" />
            }
            else
            {
                <div class="library-setup">
                    <h2>Stadia Maps API key required</h2>
                    <p>Add your Stadia Maps API key to load the online map.</p>
                    <input @bind="_stadiaApiKeyInput" placeholder="Stadia API key" />
                    <div class="setup-actions">
                        <button @onclick="SaveStadiaApiKey">Save API key</button>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="library-setup">
                <h2>@LibrarySetupTitle</h2>
                <p>@LibrarySetupMessage</p>
                <code>@DefaultLibraryPath</code>
                <div class="setup-actions">
                    <button @onclick="CreateDefaultLibrary">Create default library</button>
                    <button @onclick="ChooseLibrary">Choose folder</button>
                    <button @onclick="ApplicationShutdown.Shutdown">Exit</button>
                </div>
            </div>
        }
    </section>

    @if (ShellState.IsRightPanelOpen && _pointForm is not null)
    {
        <aside class="right-panel">
            <header class="panel-header">
                <div>
                    <h2>@PointPanelTitle</h2>
                    <p>@PointPanelSubtitle</p>
                </div>
                <button class="icon-button" title="Close point panel" @onclick="ClosePointPanel">Close</button>
            </header>

            <section class="panel-section">
                <label>
                    Title
                    <input @bind="_pointForm.Title" />
                </label>
                @if (!string.IsNullOrWhiteSpace(_titleError))
                {
                    <p class="field-error">@_titleError</p>
                }
            </section>

            <section class="panel-section">
                <h3>Coordinates</h3>
                <div class="coordinate-grid">
                    <label>
                        Latitude
                        <input value="@_pointForm.Latitude.ToString("F6")" readonly />
                    </label>
                    <label>
                        Longitude
                        <input value="@_pointForm.Longitude.ToString("F6")" readonly />
                    </label>
                </div>
            </section>

            <section class="panel-section">
                <label>
                    Address / Region
                    <input @bind="_pointForm.AddressRegion" />
                </label>
            </section>

            <section class="panel-section">
                <h3>Description</h3>
                <textarea @bind="_pointForm.DescriptionText"></textarea>
            </section>

            <section class="panel-section">
                <label>
                    Tags
                    <input @bind="_pointForm.TagsText" placeholder="#hardmode #safe #rentcar" />
                </label>
                @if (!string.IsNullOrWhiteSpace(_tagsError))
                {
                    <p class="field-error">@_tagsError</p>
                }
            </section>

            <section class="panel-section">
                <h3>Collections</h3>
                @if (_collections.Count == 0)
                {
                    <div class="empty-box">Create collections in the left panel.</div>
                }
                else
                {
                    @foreach (var collection in _collections.OrderBy(collection => collection.Name, StringComparer.OrdinalIgnoreCase))
                    {
                        <label class="check-row">
                            <input type="checkbox"
                                   checked="@IsPointInCollection(collection.Id)"
                                   @onchange="eventArgs => TogglePointCollection(collection.Id, eventArgs.Value is true)" />
                            <span class="collection-style small" style="background:@collection.Color">
                                <i class="bi bi-@IconOrDefault(collection.IconId)"></i>
                            </span>
                            <span>@collection.Name</span>
                        </label>
                    }

                    <label>
                        Primary collection
                        <select value="@(_pointForm.PrimaryCollectionId?.ToString() ?? string.Empty)"
                                disabled="@(_pointForm.CollectionIds.Count == 0)"
                                @onchange="HandlePrimaryCollectionChanged">
                            <option value="">None</option>
                            @foreach (var collection in SelectedPointCollections)
                            {
                                <option value="@collection.Id">@collection.Name</option>
                            }
                        </select>
                    </label>
                }
            </section>

            <section class="panel-section">
                <button @onclick="AddPendingAttachments">Add files</button>
            </section>

            <section class="panel-section">
                <h3>Photos</h3>
                @if (!PhotoItems.Any())
                {
                    <div class="empty-box">No photos.</div>
                }
                else
                {
                    <div class="photo-grid">
                        @foreach (var photo in PhotoItems)
                        {
                            <div class="photo-tile">
                                <button class="photo-preview" @onclick="() => OpenPhotoViewer(photo.Path)">
                                    <img src="@ToImageSource(photo.Path)" alt="@photo.DisplayName" />
                                </button>
                                <span title="@photo.DisplayName">@photo.DisplayName</span>
                                <button class="compact-button"
                                        @onclick="() => RemoveAttachment(photo)">
                                    Delete
                                </button>
                            </div>
                        }
                    </div>
                }
            </section>

            <section class="panel-section">
                <h3>Files</h3>
                @if (!FileItems.Any())
                {
                    <div class="empty-box">No files.</div>
                }
                else
                {
                    <div class="file-list">
                        @foreach (var file in FileItems)
                        {
                            <div class="file-row">
                                <button @onclick="() => OpenAttachment(file)">@file.DisplayName</button>
                                <button class="compact-button"
                                        @onclick="() => RemoveAttachment(file)">
                                    Delete
                                </button>
                            </div>
                        }
                    </div>
                }
            </section>

            @if (!string.IsNullOrWhiteSpace(_generalError))
            {
                <p class="field-error">@_generalError</p>
            }

            @if (_deleteErrors.Count > 0)
            {
                <div class="error-box">
                    @foreach (var error in _deleteErrors)
                    {
                        <p>@error</p>
                    }
                </div>
            }

            @if (_attachmentErrors.Count > 0)
            {
                <div class="error-box">
                    @foreach (var error in _attachmentErrors)
                    {
                        <p>@error</p>
                    }
                </div>
            }

            <div class="panel-actions">
                <button @onclick="SavePoint">Save</button>
                @if (!_isNewPoint)
                {
                    <button class="danger-button" @onclick="DeletePoint">Delete</button>
                }
            </div>
        </aside>
    }

    @if (!string.IsNullOrWhiteSpace(_photoViewerPath))
    {
        <div class="photo-viewer">
            <button class="photo-viewer-backdrop" @onclick="ClosePhotoViewer"></button>
            <div class="photo-viewer-content">
                <img src="@ToImageSource(_photoViewerPath)" alt="Photo preview" />
                <button @onclick="ClosePhotoViewer">Close</button>
            </div>
        </div>
    }

    <footer class="status-bar">
        <span>Visible: @_filteredPoints.Count / Total: @_allPoints.Count</span>
        <span>@StatusMessage</span>
        <div class="status-action">
            <span class="muted">@SelectedCoordinateStatus</span>
            <button disabled="@IsAddPointDisabled" @onclick="OpenNewPointPanel">Add point</button>
        </div>
    </footer>
</main>

@code {
    private static readonly IReadOnlyList<string> BootstrapIconIds =
    [
        "geo-alt-fill", "pin-map-fill", "map-fill", "compass-fill", "camera-fill", "image-fill",
        "sun-fill", "moon-stars-fill", "cloud-sun-fill", "water", "tree-fill", "flower1",
        "fire", "umbrella-fill", "snow", "star-fill", "heart-fill", "flag-fill", "bookmark-fill",
        "signpost-fill", "binoculars-fill", "backpack-fill", "car-front-fill", "taxi-front-fill",
        "bus-front-fill", "train-front-fill", "airplane-fill", "bicycle", "scooter", "fuel-pump-fill",
        "house-door-fill", "building-fill", "buildings-fill", "hospital-fill", "shop", "basket-fill",
        "cart-fill", "bag-fill", "cup-hot-fill", "cup-straw", "egg-fried", "cake2-fill",
        "fork-knife", "geo-fill", "crosshair", "bullseye", "diamond-fill", "circle-fill",
        "square-fill", "triangle-fill", "hexagon-fill", "lightning-fill", "gem", "key-fill",
        "shield-fill", "calendar-event-fill", "clock-fill", "wifi", "telephone-fill", "link-45deg",
        "file-earmark-pdf-fill", "journal-text", "book-fill", "palette-fill", "tools", "gear-fill",
        "person-walking", "cash-coin", "gift-fill", "trophy-fill", "rocket-takeoff-fill", "magic",
        "brightness-high-fill", "thermometer-sun", "droplet-fill", "wind", "layers-fill",
        "collection-fill", "tags-fill", "filter-circle-fill", "funnel-fill", "search", "grip-vertical",
        "trash-fill", "pencil-fill", "save-fill",
    ];

    private AppSettings _appSettings = new();
    private IReadOnlyList<PointDocument> _allPoints = Array.Empty<PointDocument>();
    private IReadOnlyList<PointDocument> _filteredPoints = Array.Empty<PointDocument>();
    private IReadOnlyList<CollectionDocument> _collections = Array.Empty<CollectionDocument>();
    private IReadOnlyList<MapPoint> _mapPoints = Array.Empty<MapPoint>();
    private IReadOnlyList<string> _tagIndex = Array.Empty<string>();
    private readonly List<Guid> _selectedCollectionFilterIds = [];
    private readonly List<string> _selectedTagFilters = [];
    private MapView? _mapView;
    private FilterMode _collectionFilterMode = FilterMode.Any;
    private FilterMode _tagFilterMode = FilterMode.Any;
    private Guid? _draggedCollectionFilterId;
    private MapCoordinate? _selectedCoordinate;
    private PointDocument? _pointForm;
    private PointDocument? _savedPointSnapshot;
    private CollectionDocument? _collectionForm;
    private CollectionDocument? _savedCollectionSnapshot;
    private string _stadiaApiKeyInput = string.Empty;
    private string _searchInput = string.Empty;
    private string? _activeSearchQuery;
    private string _iconSearch = string.Empty;
    private string? _titleError;
    private string? _tagsError;
    private string? _generalError;
    private string? _photoViewerPath;
    private string? _collectionNameError;
    private string? _collectionColorError;
    private string? _collectionGeneralError;
    private IReadOnlyList<string> _deleteErrors = Array.Empty<string>();
    private IReadOnlyList<string> _attachmentErrors = Array.Empty<string>();
    private IReadOnlyList<string> _collectionDeleteErrors = Array.Empty<string>();
    private List<PendingAttachment> _pendingAttachments = [];
    private int _pointLoadErrorCount;
    private int _collectionLoadErrorCount;
    private bool _isNewPoint;
    private bool _isNewCollection;

    private bool IsLibraryReady { get; set; }

    private string? LibraryPath { get; set; }

    private string DefaultLibraryPath => EnvironmentPaths.DefaultLibraryPath;

    private string LibrarySetupTitle { get; set; } = "Choose ChoKuda library";

    private string LibrarySetupMessage { get; set; } =
        "Create a new library in the default location or choose an existing library folder.";

    private bool HasStadiaApiKey =>
        !string.IsNullOrWhiteSpace(_appSettings.StadiaApiKey);

    private string StadiaApiKey =>
        _appSettings.StadiaApiKey ?? string.Empty;

    private bool IsAddPointDisabled =>
        !IsLibraryReady || _selectedCoordinate is null || ShellState.IsRightPanelOpen;

    private string SelectedCoordinateStatus =>
        _selectedCoordinate is null
            ? "No map point selected"
            : $"{_selectedCoordinate.Latitude:F5}, {_selectedCoordinate.Longitude:F5}";

    private string PointPanelTitle =>
        _isNewPoint ? "New point" : "Edit point";

    private string PointPanelSubtitle =>
        _isNewPoint ? "Unsaved draft" : "Saved point";

    private string StatusMessage =>
        $"Search: {(IsSearchActive ? "active" : "none")} | " +
        $"Collections: {_selectedCollectionFilterIds.Count} {_collectionFilterMode.ToString().ToUpperInvariant()} | " +
        $"Tags: {_selectedTagFilters.Count} {_tagFilterMode.ToString().ToUpperInvariant()} | " +
        $"JSON errors: {_pointLoadErrorCount + _collectionLoadErrorCount}";

    private string ShellClass =>
        ShellState.IsLeftPanelCollapsed
            ? "app-shell left-collapsed"
            : "app-shell";

    private bool HasUnsavedPointChanges =>
        _pointForm is not null &&
        (_isNewPoint || !PointDocumentsEqual(_pointForm, _savedPointSnapshot));

    private bool HasUnsavedCollectionChanges =>
        _collectionForm is not null &&
        (_isNewCollection || !CollectionDocumentsEqual(_collectionForm, _savedCollectionSnapshot));

    private bool IsSearchActive =>
        !string.IsNullOrWhiteSpace(_activeSearchQuery);

    private bool CanRunSearch =>
        !string.IsNullOrWhiteSpace(_searchInput);

    private IEnumerable<PointDocument> SearchResults =>
        _filteredPoints
            .OrderBy(point => point.Title, StringComparer.CurrentCultureIgnoreCase)
            .ThenBy(point => point.Id);

    private IEnumerable<string> FilteredIconIds =>
        BootstrapIconIds
            .Where(iconId => string.IsNullOrWhiteSpace(_iconSearch) || iconId.Contains(_iconSearch.Trim(), StringComparison.OrdinalIgnoreCase))
            .Take(48);

    private IEnumerable<CollectionDocument> SelectedPointCollections =>
        _collections
            .Where(collection => _pointForm?.CollectionIds.Contains(collection.Id) == true)
            .OrderBy(collection => collection.Name, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<AttachmentDisplayItem> PhotoItems =>
        GetAttachmentDisplayItems(AttachmentKind.Photo);

    private IEnumerable<AttachmentDisplayItem> FileItems =>
        GetAttachmentDisplayItems(AttachmentKind.File);

    protected override void OnInitialized()
    {
        ShellState.Changed += HandleStateChanged;
        LoadLibraryState();
    }

    public void Dispose()
    {
        ShellState.Changed -= HandleStateChanged;
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void LoadLibraryState()
    {
        _appSettings = AppSettingsService.Load();
        _stadiaApiKeyInput = _appSettings.StadiaApiKey ?? string.Empty;

        if (string.IsNullOrWhiteSpace(_appSettings.LibraryPath))
        {
            IsLibraryReady = false;
            LibraryPath = null;
            LibrarySetupTitle = "Choose ChoKuda library";
            LibrarySetupMessage = "Create a new library in the default location or choose an existing library folder.";
            return;
        }

        if (!Directory.Exists(_appSettings.LibraryPath))
        {
            IsLibraryReady = false;
            LibraryPath = _appSettings.LibraryPath;
            LibrarySetupTitle = "Library not found";
            LibrarySetupMessage = "The saved ChoKuda library folder is missing or unavailable.";
            return;
        }

        FileLibraryService.EnsureLibrary(_appSettings.LibraryPath);
        IsLibraryReady = true;
        LibraryPath = _appSettings.LibraryPath;
        LoadLibraryData();
    }

    private void CreateDefaultLibrary()
    {
        UseLibrary(DefaultLibraryPath);
    }

    private void ChooseLibrary()
    {
        var selectedPath = LibraryFolderPicker.PickFolder(LibraryPath ?? DefaultLibraryPath);

        if (!string.IsNullOrWhiteSpace(selectedPath))
        {
            UseLibrary(selectedPath);
        }
    }

    private void UseLibrary(string libraryPath)
    {
        FileLibraryService.EnsureLibrary(libraryPath);
        _appSettings.LibraryPath = libraryPath;
        AppSettingsService.Save(_appSettings);
        IsLibraryReady = true;
        LibraryPath = libraryPath;
        LoadLibraryData();
    }

    private void LoadLibraryData()
    {
        if (string.IsNullOrWhiteSpace(LibraryPath))
        {
            _allPoints = Array.Empty<PointDocument>();
            _collections = Array.Empty<CollectionDocument>();
            _pointLoadErrorCount = 0;
            _collectionLoadErrorCount = 0;
            ApplyFiltersAndMapProjection();
            return;
        }

        var paths = new FileLibraryPaths(LibraryPath);
        var pointsResult = FileLibraryService.LoadPoints(paths);
        var collectionsResult = FileLibraryService.LoadCollections(paths);
        _allPoints = pointsResult.Items;
        _collections = collectionsResult.Items;
        _tagIndex = TagIndex.Build(_allPoints);
        _pointLoadErrorCount = pointsResult.Errors.Count;
        _collectionLoadErrorCount = collectionsResult.Errors.Count;
        RemoveMissingFilterValues();
        ApplyFiltersAndMapProjection();
    }

    private void ApplyFiltersAndMapProjection()
    {
        var searchedPoints = IsSearchActive
            ? SearchService.Apply(_allPoints, _activeSearchQuery!)
            : _allPoints;

        _filteredPoints = PointFilterService.Apply(
            searchedPoints,
            new PointFilterOptions(
                _selectedCollectionFilterIds,
                _collectionFilterMode,
                _selectedTagFilters,
                _tagFilterMode));
        _mapPoints = MapPointProjection.FromPointDocuments(
            _filteredPoints,
            _collections.Select(collection => new CollectionMapStyle(collection.Id, IconOrDefault(collection.IconId), collection.Color)),
            _selectedCollectionFilterIds);
    }

    private void RemoveMissingFilterValues()
    {
        _selectedCollectionFilterIds.RemoveAll(collectionId => _collections.All(collection => collection.Id != collectionId));
        _selectedTagFilters.RemoveAll(tag => !_tagIndex.Contains(tag, StringComparer.Ordinal));
    }

    private void SaveStadiaApiKey()
    {
        _appSettings.StadiaApiKey = string.IsNullOrWhiteSpace(_stadiaApiKeyInput)
            ? null
            : _stadiaApiKeyInput.Trim();

        AppSettingsService.Save(_appSettings);
    }

    private void HandleMapClick(MapCoordinate coordinate)
    {
        if (ShellState.IsRightPanelOpen)
        {
            return;
        }

        _selectedCoordinate = coordinate;
    }

    private async Task HandlePointClick(Guid pointId)
    {
        await OpenSavedPoint(pointId);
    }

    private async Task OpenSearchResult(Guid pointId)
    {
        var point = _allPoints.FirstOrDefault(point => point.Id == pointId);

        if (point is null)
        {
            LoadLibraryData();
            return;
        }

        if (await OpenSavedPoint(pointId) && _mapView is not null)
        {
            await _mapView.CenterOnAsync(point.Latitude, point.Longitude);
        }
    }

    private async Task<bool> OpenSavedPoint(Guid pointId)
    {
        if (!await ConfirmDiscardChangesIfNeeded())
        {
            return false;
        }

        var paths = GetCurrentLibraryPaths();
        if (paths is null)
        {
            return false;
        }

        var point = PointService.LoadPoint(paths, pointId);
        if (point is null)
        {
            LoadLibraryData();
            return false;
        }

        _selectedCoordinate = null;
        _pointForm = ClonePoint(point);
        _savedPointSnapshot = ClonePoint(point);
        _pendingAttachments = [];
        _isNewPoint = false;
        ClearPointErrors();
        ShellState.OpenRightPanelPreview();
        return true;
    }

