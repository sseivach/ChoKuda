<div class="library-setup">
    <h2>Stadia Maps API key required</h2>
    <p>Add your Stadia Maps API key to load the online map.</p>
    <input value="@StadiaApiKeyInput"
           @oninput="UpdateStadiaApiKeyInput"
           placeholder="Stadia API key" />
    <MapStyleSelect CssClass="map-style-select setup-map-style"
                    StyleOptions="@MapStyleOptions"
                    SelectedStyleId="@SelectedMapStyleId"
                    OnStyleChanged="OnMapStyleChanged" />
    <label class="map-option-toggle setup-map-toggle">
        <input type="checkbox"
               checked="@UseLargeMapLabels"
               @onchange="UpdateLargeMapLabels" />
        <span>Large labels</span>
    </label>
    <div class="setup-actions">
        <button @onclick="OnSaveStadiaApiKey">Save API key</button>
    </div>
</div>

@code {
    [Parameter]
    public string StadiaApiKeyInput { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> OnStadiaApiKeyInputChanged { get; set; }

    [Parameter]
    public IReadOnlyList<StadiaMapStyle> MapStyleOptions { get; set; } = Array.Empty<StadiaMapStyle>();

    [Parameter]
    public string SelectedMapStyleId { get; set; } = StadiaMapStyles.DefaultStyleId;

    [Parameter]
    public EventCallback<string> OnMapStyleChanged { get; set; }

    [Parameter]
    public bool UseLargeMapLabels { get; set; }

    [Parameter]
    public EventCallback<bool> OnLargeMapLabelsChanged { get; set; }

    [Parameter]
    public EventCallback OnSaveStadiaApiKey { get; set; }

    private async Task UpdateStadiaApiKeyInput(ChangeEventArgs eventArgs)
    {
        await OnStadiaApiKeyInputChanged.InvokeAsync(eventArgs.Value?.ToString() ?? string.Empty);
    }

    private async Task UpdateLargeMapLabels(ChangeEventArgs eventArgs)
    {
        await OnLargeMapLabelsChanged.InvokeAsync(eventArgs.Value is true);
    }
}
